{
  "name": "@csbc-dev/stripe",
  "version": "0.4.0",
  "description": "Declarative Stripe payments component for Web Components. Server-side intent creation, browser-direct card entry via Stripe Elements, no PCI scope expansion, via wc-bindable-protocol.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run __tests__",
    "test:watch": "vitest __tests__",
    "test:ci": "npm run build && vitest run __tests__",
    "test:integration": "npm run build && playwright test"
  },
  "keywords": [
    "web-components",
    "stripe",
    "payments",
    "payment-intent",
    "setup-intent",
    "3d-secure",
    "custom-elements",
    "wc-bindable",
    "declarative"
  ],
  "dependencies": {
    "@wc-bindable/core": "^0.4.0",
    "@wc-bindable/remote": "^0.4.0"
  },
  "peerDependencies": {
    "@stripe/stripe-js": "^5.0.0",
    "stripe": "^17.0.0"
  },
  "peerDependenciesMeta": {
    "stripe": {
      "optional": true
    },
    "@stripe/stripe-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@stripe/stripe-js": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "happy-dom": "^20.8.3",
    "stripe": "^17.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "ws": "^8.20.0"
  },
  "author": "mogera551",
  "repository": {
    "type": "git",
    "url": "https://github.com/wc-bindable-protocol/wc-bindable-protocol.git",
    "directory": "packages/stripe"
  },
  "license": "MIT"
}
